# ── Hardhat Keystore (encrypted, never in this file) ─────────────────────────
# Read by hardhat.config.ts via configVariable(). Stored AES-encrypted by the
# hardhat-keystore plugin — set once with the CLI, never commit a value here.
#
#   npx hardhat keystore set DEPLOYER_PRIVATE_KEY
#
# DEPLOYER_PRIVATE_KEY — EOA private key; signs deploy.ts and setup.ts txs on Arc testnet.
#                        Only key hardhat.config.ts reads — Dynamic credentials are
#                        server-side secrets, not Hardhat keystore (see section below).

# ── Dynamic server wallet ─────────────────────────────────────────────────────
# Used by the CRE workflow and Next.js server — NOT by Hardhat.
# Store in a git-ignored .env file; do not check in real values.
DYNAMIC_AUTH_TOKEN=your-api-auth-token
DYNAMIC_ENVIRONMENT_ID=your-environment-id
DYNAMIC_WALLET_PASSWORD=your-wallet-password

# ── Arc Testnet ───────────────────────────────────────────────────────────────
# Public — safe to commit.
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# ── Contract addresses ────────────────────────────────────────────────────────
# Public addresses — safe to commit once known.

# USDC token address on Arc testnet
USDC_ADDRESS=

# Sneehee's address — receives USDC when proof is approved
RECIPIENT_ADDRESS=

# Filled in after running contracts/scripts/deploy.ts
PROOF_ESCROW_ADDRESS=
