# One-time setup scripts only — not needed to run the demo.
# The running demo reads from apps/studio/.env.local and cre/.env.

# ── Dynamic server wallet ─────────────────────────────────────────────────────
# Used by scripts/create-wallet.ts to bootstrap the server wallet.
# Get from: app.dynamic.xyz → Developer → API & SDK Keys
DYNAMIC_AUTH_TOKEN=your-api-auth-token
DYNAMIC_ENVIRONMENT_ID=your-environment-id
DYNAMIC_WALLET_PASSWORD=your-wallet-password

# ── Arc Testnet ───────────────────────────────────────────────────────────────
# Optional — hardhat.config.ts defaults to https://rpc.testnet.arc.network
ARC_RPC_URL=https://rpc.testnet.arc.network

# ── Contract addresses ────────────────────────────────────────────────────────
# USDC ERC-20 system contract on Arc testnet (6 decimals)
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# SMB address — receives USDC when proof is approved
RECIPIENT_ADDRESS=

# Filled in after: cd contracts && npx hardhat run scripts/deploy.ts --network arc-testnet
PROOF_GATED_ESCROW_ADDRESS=

# ── Deployer private key ──────────────────────────────────────────────────────
# Stored encrypted in Hardhat keystore — never put the value in this file.
# Set once with: cd contracts && npx hardhat keystore set DEPLOYER_PRIVATE_KEY
