# Dynamic server wallet — get these from https://app.dynamic.xyz → your environment → API
DYNAMIC_AUTH_TOKEN=your-api-auth-token
DYNAMIC_ENVIRONMENT_ID=your-environment-id
# Choose any strong password — this encrypts the wallet key share locally. Do not lose it.
DYNAMIC_WALLET_PASSWORD=your-wallet-password

# Arc Testnet (fixed values — do not change)
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# Deployed by TECH-177 — copy the address from that deploy output
PROOF_ESCROW_ADDRESS=0xYourProofEscrowAddress

# Already deployed — get the live URL from the Orbbit AWS Lambda deployment
DAIRY_API_URL=https://your-dairy-api-url
