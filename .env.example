# ── Hardhat Keystore (encrypted, never in this file) ─────────────────────────
# Read by contracts/hardhat.config.ts via configVariable(). Stored AES-encrypted
# by the hardhat-keystore plugin — set once with the CLI, never commit a value here.
#
#   cd contracts && npx hardhat keystore set DEPLOYER_PRIVATE_KEY
#
# DEPLOYER_PRIVATE_KEY — EOA private key; signs deploy.ts and setup.ts txs on Arc testnet.
#                        Only key hardhat.config.ts reads — Dynamic credentials are
#                        server-side secrets, not Hardhat keystore (see below).

# ── Dynamic server wallet ─────────────────────────────────────────────────────
# Used by the CRE workflow and Next.js server — NOT by Hardhat.
# Get from https://app.dynamic.xyz → your environment → API
DYNAMIC_AUTH_TOKEN=your-api-auth-token
DYNAMIC_ENVIRONMENT_ID=your-environment-id
# Choose any strong password — this encrypts the wallet key share locally.
DYNAMIC_WALLET_PASSWORD=your-wallet-password

# ── Arc Testnet ───────────────────────────────────────────────────────────────
# Public — safe to commit.
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# ── External APIs ─────────────────────────────────────────────────────────────
# Already deployed on AWS Lambda — get the live URL from Orbbit deployment
DAIRY_API_URL=https://your-dairy-api-url

# ── Contract addresses ────────────────────────────────────────────────────────
# Public addresses — safe to commit once known.

# USDC ERC-20 system contract on Arc testnet (6 decimals) — source: docs.arc.io/arc/references/contract-addresses
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# SMB address — receives USDC when proof is approved
RECIPIENT_ADDRESS=

# Filled in after running: cd contracts && npx hardhat run scripts/deploy.ts --network arc
PROOF_ESCROW_ADDRESS=
