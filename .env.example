# ── Hardhat Keystore (encrypted, never in this file) ─────────────────────────
# Read by contracts/hardhat.config.ts via configVariable(). Stored AES-encrypted
# by the hardhat-keystore plugin — set once with the CLI, never commit a value here.
#
#   cd contracts && npx hardhat keystore set DEPLOYER_PRIVATE_KEY
#
# DEPLOYER_PRIVATE_KEY — EOA private key; signs deploy.ts and setup.ts txs on Arc testnet.
#                        Only key hardhat.config.ts reads — Dynamic credentials are
#                        server-side secrets, not Hardhat keystore (see below).

# ── Dynamic server wallet ─────────────────────────────────────────────────────
# Used by the CRE workflow and Next.js server — NOT by Hardhat.
# Get from https://app.dynamic.xyz → your environment → Developer → API & SDK Keys
DYNAMIC_AUTH_TOKEN=your-api-auth-token
DYNAMIC_ENVIRONMENT_ID=your-environment-id
# Choose any strong password — this encrypts the wallet key share locally.
DYNAMIC_WALLET_PASSWORD=your-wallet-password

# ── Dynamic React SDK (browser-exposed) ──────────────────────────────────────
# NEXT_PUBLIC_ prefix required — Next.js strips unprefixed vars from client bundle.
# Same value as DYNAMIC_ENVIRONMENT_ID above.
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=your-environment-id

# ── Dynamic Fireblocks Flow (TECH-184) ───────────────────────────────────────
# NEXT_PUBLIC_CHECKOUT_ID — reusable Flow checkout config UUID.
#   Create once: POST /environments/{envId}/flow/checkouts with destination = server wallet on Arc.
#   Dashboard: app.dynamic.xyz → Accept Stablecoins & Crypto → Fireblocks Flow (activate first).
NEXT_PUBLIC_CHECKOUT_ID=your-checkout-id

# NEXT_PUBLIC_DEAL_ID — which ProofGatedEscrow deal to fund via Flow.
#   Deal #1 = M0 demo (already RELEASED). Deal #2 = M1 Investor Trust Portal target.
NEXT_PUBLIC_DEAL_ID=2

# NEXT_PUBLIC_USDC_ADDRESS — same contract as USDC_ADDRESS below; prefixed so
#   FlowDeposit.tsx can read it in the browser for the quote call.
NEXT_PUBLIC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# DYNAMIC_WEBHOOK_SECRET — HMAC-SHA256 key for verifying Dynamic settlement webhooks.
#   Get from: app.dynamic.xyz → Developers → Webhooks → register /api/flow-webhook → copy secret.
DYNAMIC_WEBHOOK_SECRET=your-webhook-secret

# ── Arc Testnet ───────────────────────────────────────────────────────────────
# Public — safe to commit.
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# ── External APIs ─────────────────────────────────────────────────────────────
# Deployed on AWS Lambda — paid via x402 on Base Sepolia.
DAIRY_API_URL=https://g78md4c7ke.execute-api.us-east-1.amazonaws.com/dairy/cream/price

# ── x402 payment wallet (Base Sepolia) ───────────────────────────────────────
# EOA private key on Base Sepolia — must hold testnet USDC to pay for dairy price API queries.
# Fund at: https://faucet.circle.com (select Base Sepolia, request USDC).
X402_PRIVATE_KEY=your-base-sepolia-eoa-private-key

# ── Contract addresses ────────────────────────────────────────────────────────
# Public addresses — safe to commit once known.

# USDC ERC-20 system contract on Arc testnet (6 decimals) — source: docs.arc.io/arc/references/contract-addresses
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# SMB address — receives USDC when proof is approved
RECIPIENT_ADDRESS=

# Filled in after running: cd contracts && npx hardhat run scripts/deploy.ts --network arc
PROOF_GATED_ESCROW_ADDRESS=
